# .env.example — copy this to .env and fill in the values
#
# ⚠  NO AI API keys belong here. All AI credentials live server-side
#    in your serverless proxy environment (e.g. Vercel / Netlify env vars).
#
# VITE_PROXY_TARGET — local dev only. Points to your local serverless gateway.
#                     In production this variable is unused; /api routes are native.
VITE_PROXY_TARGET=http://localhost:3001
